# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_PREFIX=-
BOT_NAME=DJ DIDZ

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bot.log

# Features
ENABLE_AUTOCORRECT=true
AUTOCORRECT_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_COMMANDS=5
RATE_LIMIT_WINDOW_MS=10000

# Database
DATABASE_PATH=data/bot.db

# Voice Settings
DEFAULT_VOLUME=50
PREMIUM_MAX_QUEUE_SIZE=100
FREE_MAX_QUEUE_SIZE=50
